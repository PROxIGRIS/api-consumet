{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ESNext",
    "lib": ["ESNext"],

    /* Modules */
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": "./",
    "rootDir": "src",
    "paths": {
      "*": ["node_modules/*", "src/types/*"]
    },                                     
    
    /* Emit */
    "outDir": "dist",
    "sourceMap": true,
    "noEmitOnError": false, /* Force emit even with errors */

    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking - THE "MERCENARY" SETTINGS */
    "strict": false, /* Disable all strict checks */
    "noImplicitAny": false, /* Stop complaining about 'any' types */
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "strictPropertyInitialization": false,
    "noImplicitThis": false,
    "alwaysStrict": false,

    /* Completeness */
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "bin/**"
  ]
}
